{
  "name": "@neurologix/schemas",
  "version": "0.1.0",
  "description": "Data schemas and validation for NeuroLogix platform",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist",
    "dev": "npm run build:watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "generate:json-schema": "typescript-json-schema tsconfig.json '*' --out schemas.json"
  },
  "dependencies": {
    "@neurologix/core": "*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.67.1",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
