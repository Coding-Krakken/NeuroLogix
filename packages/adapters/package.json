{
  "name": "@neurologix/adapters",
  "version": "0.1.0",
  "description": "Protocol adapter and simulator slices for NeuroLogix edge ingestion",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "npm run build:watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@neurologix/schemas": "*",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.3.2",
    "vitest": "^3.2.4"
  },
  "publishConfig": {
    "access": "restricted"
  }
}