{
  "name": "@neurologix/security-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Core security utilities for service authentication, mTLS, and audit logging",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc --build",
    "lint": "eslint src --ext .ts",
    "test": "vitest --config vitest.config.ts",
    "test:ci": "vitest run --coverage --config vitest.config.ts",
    "test:opa": "opa test src/policies --format pretty"
  },
  "dependencies": {
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^3.2.0",
    "eslint": "^8.50.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0"
  }
}
