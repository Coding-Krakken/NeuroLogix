{
  "name": "@subzero/framework",
  "version": "2.0.0",
  "description": "SubZero Agentic Framework - Enterprise-grade orchestration for 28 specialized AI agents",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/**",
    "README.md",
    "CHANGELOG.md",
    "API-CONTRACTS.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json}\"",
    "build": "tsc",
    "governance:route:issue": "node --loader ts-node/esm governance/deterministic-router.ts --kind issue --mode enforce",
    "governance:route:pr": "node --loader ts-node/esm governance/deterministic-router.ts --kind pr --mode enforce",
    "governance:changelog": "node --loader ts-node/esm governance/enforce-changelog-version.ts",
    "governance:boundary": "node --loader ts-node/esm governance/enforce-framework-boundary.ts",
    "governance:policy": "node --loader ts-node/esm governance/enforce-policy-conformance.ts --mode enforce",
    "governance:model:advisory": "node --loader ts-node/esm governance/enforce-model-completeness.ts --mode advisory",
    "governance:model:enforce": "node --loader ts-node/esm governance/enforce-model-completeness.ts --mode enforce",
    "handoff:report": "tsc && node dist/src/handoff-workflow-report-cli.js"
  },
  "dependencies": {
    "@types/node": "^25.3.3"
  },
  "devDependencies": {
    "@jest/globals": "^30.2.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "agentic",
    "framework",
    "orchestration",
    "github",
    "copilot",
    "ai-agents",
    "workflow"
  ],
  "author": "SubZero Engineering",
  "license": "UNLICENSED",
  "private": false
}
