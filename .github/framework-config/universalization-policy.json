{
  "removeDirectories": [
    ".github/.handoffs",
    ".github/issue-bodies",
    ".github/pr-bodies",
    ".github/prompts_original"
  ],
  "removeFileGlobs": [
    ".github/.system-state/**/*issue*.*",
    ".github/.system-state/**/*fullstack*.*",
    ".github/.system-state/**/*limited_release*.*",
    ".github/.system-state/**/*universal_framework_adoption*.*",
    ".github/.system-state/**/*hybrid_phase*.*",
    ".github/DECISIONS/ADR-*issue-*.*",
    ".github/DECISIONS/ADR-*hybrid-*.*"
  ],
  "removeFileRegex": [
    "(?i)^\\.github/.+/(issue[-_ ]?[0-9]+|issue[0-9]+|pr[-_ ]?[0-9]+).+",
    "(?i)^\\.github/.+/handoff-\\d{8}-.+\\.md$"
  ],
  "scrub": {
    "includeFileGlobs": [
      "CHANGELOG.md",
      ".github/**/*.md",
      ".github/**/*.yaml",
      ".github/**/*.yml"
    ],
    "excludeFileGlobs": [
      ".github/.handoffs/**",
      ".github/issue-bodies/**",
      ".github/pr-bodies/**",
      ".github/prompts_original/**",
      ".github/framework/node_modules/**"
    ],
    "replacements": [
      {
        "pattern": "(?i)<APPLICATION_NAME>",
        "replacement": "<APPLICATION_NAME>",
        "isRegex": true
      },
      {
        "pattern": "(?i)SubZero Agentic Framework|SubZero",
        "replacement": "<FRAMEWORK_NAME>",
        "isRegex": true
      },
      {
        "pattern": "(?i)<ORGANIZATION_NAME>",
        "replacement": "<ORGANIZATION_NAME>",
        "isRegex": true
      },
      {
        "pattern": "(?i)<REPOSITORY_NAME>",
        "replacement": "<REPOSITORY_NAME>",
        "isRegex": true
      },
      {
        "pattern": "(?i)<PRIMARY_REGION>",
        "replacement": "<PRIMARY_REGION>",
        "isRegex": true
      },
      {
        "pattern": "(?i)Next\\.js 14( App Router)?",
        "replacement": "<WEB_FRAMEWORK>",
        "isRegex": true
      },
      {
        "pattern": "(?i)<PAYMENT_PROVIDER>( Online Store| APIs| API| Web Payments SDK| hosted checkout|-hosted checkout)?",
        "replacement": "<PAYMENT_PROVIDER>",
        "isRegex": true
      },
      {
        "pattern": "(?i)<DEPLOYMENT_PLATFORM>",
        "replacement": "<DEPLOYMENT_PLATFORM>",
        "isRegex": true
      },
      {
        "pattern": "(?i)feature/issue-[0-9]+-[a-z0-9-]+",
        "replacement": "feature/<WORK_ITEM_SLUG>",
        "isRegex": true
      },
      {
        "pattern": "(?i)Issue\\s*#\\d+",
        "replacement": "Issue #<N>",
        "isRegex": true
      }
    ]
  }
}

