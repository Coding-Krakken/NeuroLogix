{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://subzero.dev/policies/work-item.schema.json",
  "title": "SubZeroWorkItem",
  "type": "object",
  "required": [
    "id",
    "title",
    "type",
    "state",
    "priority",
    "severity",
    "risk",
    "blast_radius",
    "component_area",
    "deployment_surface",
    "rollout_method",
    "data_sensitivity",
    "owner_agent",
    "approvals",
    "artifacts"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Z]+-[0-9]+$"
    },
    "title": {
      "type": "string",
      "minLength": 8
    },
    "type": {
      "type": "string",
      "enum": [
        "feature",
        "enhancement",
        "bug",
        "security-vulnerability",
        "security-hardening",
        "incident",
        "hotfix",
        "dependency-update",
        "refactor",
        "tech-debt",
        "performance",
        "reliability",
        "ci-cd",
        "infrastructure",
        "observability",
        "data-migration",
        "schema-change",
        "api-change",
        "breaking-api-change",
        "compliance",
        "legal-review",
        "privacy-change",
        "documentation",
        "ux-design",
        "experiment",
        "customer-escalation",
        "release"
      ]
    },
    "state": {
      "type": "string",
      "enum": [
        "draft",
        "triage",
        "planned",
        "in-progress",
        "in-review",
        "approved",
        "ready-to-release",
        "released",
        "verified",
        "blocked",
        "closed",
        "cancelled"
      ]
    },
    "priority": {
      "type": "string",
      "enum": ["P0", "P1", "P2", "P3"]
    },
    "severity": {
      "type": "string",
      "enum": ["S0", "S1", "S2", "S3", "S4"]
    },
    "risk": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "blast_radius": {
      "type": "string",
      "enum": ["single-team", "multi-team", "customer-visible", "global"]
    },
    "component_area": {
      "type": "string",
      "enum": ["frontend", "backend", "data", "infra", "security", "platform", "docs"]
    },
    "deployment_surface": {
      "type": "string",
      "enum": ["non-prod", "prod"]
    },
    "rollout_method": {
      "type": "string",
      "enum": ["all-at-once", "flag", "ring", "canary"]
    },
    "data_sensitivity": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "regulated"]
    },
    "owner_agent": {
      "type": "string"
    },
    "stakeholders": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "approvals": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "status"],
        "properties": {
          "role": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["required", "approved", "waived"]
          },
          "evidence": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status"],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["required", "present", "n/a"]
          },
          "link": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
