{
  "version": "1.0.0",
  "defaults": {
    "requiredApprovers": ["orchestrator-agent", "assurance-agent"],
    "requiredChecks": ["unit", "integration", "lint", "typecheck"],
    "requiredDocs": ["issue-complete", "pr-template-complete"],
    "rolloutRequirements": ["rollback-plan"],
    "mergeStrategy": "squash",
    "commitFormat": "<type>(<scope>): <subject>",
    "releaseRequirements": ["release-notes"]
  },
  "byType": {
    "feature": {
      "risk": "medium",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent"],
      "requiredChecks": ["unit", "integration", "e2e", "lint", "typecheck"],
      "requiredDocs": ["acceptance-criteria", "runbook-update"],
      "rolloutRequirements": ["feature-flag", "ring-rollout", "monitoring-plan"],
      "releaseRequirements": ["changelog", "release-notes"]
    },
    "bug": {
      "risk": "medium",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent"],
      "requiredChecks": ["unit", "integration", "regression"],
      "requiredDocs": ["root-cause-summary"],
      "rolloutRequirements": ["rollback-plan"]
    },
    "security-vulnerability": {
      "risk": "critical",
      "requiredApprovers": ["assurance-agent", "security-engineer", "legal-counsel"],
      "requiredChecks": ["security-scan", "unit", "integration", "regression"],
      "requiredDocs": ["security-advisory", "mitigation-notes"],
      "rolloutRequirements": ["canary", "enhanced-monitoring"],
      "releaseRequirements": ["security-release-notes"]
    },
    "incident": {
      "risk": "critical",
      "requiredApprovers": ["assurance-agent", "incident-commander"],
      "requiredChecks": ["smoke", "incident-validation"],
      "requiredDocs": ["incident-log", "postmortem"],
      "rolloutRequirements": ["incident-mode"],
      "releaseRequirements": ["incident-summary"]
    },
    "hotfix": {
      "risk": "high",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent", "sre-engineer"],
      "requiredChecks": ["targeted", "smoke", "lint"],
      "requiredDocs": ["hotfix-rationale", "follow-up-issue"],
      "rolloutRequirements": ["canary", "rollback-plan"]
    },
    "data-migration": {
      "risk": "critical",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent", "data-engineer", "sre-engineer"],
      "requiredChecks": ["migration-dry-run", "integration", "data-validation", "rollback-test"],
      "requiredDocs": ["migration-plan", "compatibility-plan", "rollback-runbook"],
      "rolloutRequirements": ["ring-rollout", "enhanced-monitoring"],
      "releaseRequirements": ["migration-notes", "release-notes"]
    },
    "breaking-api-change": {
      "risk": "critical",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent", "solution-architect", "documentation-engineer"],
      "requiredChecks": ["integration", "consumer-contract", "e2e"],
      "requiredDocs": ["api-rfc", "deprecation-plan", "migration-guide"],
      "rolloutRequirements": ["dual-run", "versioning-plan"],
      "releaseRequirements": ["major-version-bump", "release-notes"]
    },
    "compliance": {
      "risk": "high",
      "requiredApprovers": ["assurance-agent", "legal-counsel", "privacy-compliance-officer", "security-engineer"],
      "requiredChecks": ["compliance-validation", "security-scan"],
      "requiredDocs": ["control-mapping", "audit-evidence"],
      "rolloutRequirements": ["controlled-rollout"]
    },
    "refactor": {
      "risk": "low",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent"],
      "requiredChecks": ["unit", "integration", "lint", "typecheck"],
      "requiredDocs": ["invariant-checklist"],
      "rolloutRequirements": ["rollback-plan"]
    },
    "performance": {
      "risk": "medium",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent", "performance-engineer"],
      "requiredChecks": ["perf-benchmark", "unit", "integration"],
      "requiredDocs": ["perf-baseline", "perf-results"],
      "rolloutRequirements": ["canary", "monitoring-plan"]
    },
    "ci-cd": {
      "risk": "medium",
      "requiredApprovers": ["orchestrator-agent", "assurance-agent", "platform-engineer"],
      "requiredChecks": ["pipeline-self-test", "lint", "typecheck"],
      "requiredDocs": ["pipeline-change-notes", "rollback-runbook"],
      "rolloutRequirements": ["staged-enable"]
    },
    "dependency-update": {
      "risk": "low",
      "requiredApprovers": ["orchestrator-agent"],
      "requiredChecks": ["unit", "integration", "dependency-scan"],
      "requiredDocs": ["dependency-impact-note"]
    }
  },
  "overrides": {
    "bySeverity": {
      "S0": {
        "requiredApprovers": ["executive-sponsor", "assurance-agent"],
        "requiredChecks": ["incident-validation", "security-scan"],
        "rolloutRequirements": ["incident-mode", "canary", "rollback-drill"]
      },
      "S1": {
        "requiredApprovers": ["assurance-agent"],
        "requiredChecks": ["smoke", "regression"]
      }
    },
    "byRisk": {
      "critical": {
        "requiredApprovers": ["assurance-agent"],
        "requiredChecks": ["security-scan", "perf-benchmark"],
        "requiredDocs": ["runbook-update", "rollback-runbook"]
      },
      "high": {
        "requiredChecks": ["security-scan"]
      }
    },
    "byDataSensitivity": {
      "regulated": {
        "requiredApprovers": ["assurance-agent", "privacy-compliance-officer", "legal-counsel"],
        "requiredChecks": ["privacy-review", "compliance-validation"],
        "requiredDocs": ["data-protection-impact-assessment"]
      },
      "confidential": {
        "requiredApprovers": ["assurance-agent", "security-engineer"],
        "requiredChecks": ["secrets-scan"]
      }
    },
    "byDeploymentSurface": {
      "prod": {
        "requiredApprovers": ["assurance-agent", "sre-engineer"],
        "requiredChecks": ["smoke", "observability-check"],
        "rolloutRequirements": ["monitoring-plan", "rollback-plan"],
        "releaseRequirements": ["release-notes", "changelog"]
      }
    }
  },
  "fallback": "deny_with_clarification"
}
