{
  "version": "1.0.0",
  "universal": {
    "name": "universal-work-item",
    "states": ["draft", "triage", "planned", "in-progress", "in-review", "approved", "ready-to-release", "released", "verified", "blocked", "closed", "cancelled"],
    "allowedTransitions": {
      "draft": ["triage"],
      "triage": ["planned", "blocked", "cancelled"],
      "planned": ["in-progress", "blocked"],
      "in-progress": ["in-review", "blocked"],
      "in-review": ["approved", "in-progress", "blocked"],
      "approved": ["ready-to-release", "blocked"],
      "ready-to-release": ["released", "blocked"],
      "released": ["verified", "blocked"],
      "verified": ["closed"],
      "blocked": ["triage", "planned", "in-progress", "in-review"],
      "closed": [],
      "cancelled": []
    },
    "preconditions": {
      "draft->triage": ["required-metadata"],
      "triage->planned": ["risk-defined", "dri-assigned", "acceptance-criteria"],
      "planned->in-progress": ["implementation-plan"],
      "in-progress->in-review": ["code-complete", "ci-green", "test-evidence"],
      "in-review->approved": ["required-approvals"],
      "approved->ready-to-release": ["rollout-plan", "monitoring-plan"],
      "ready-to-release->released": ["deploy-checks-green"],
      "released->verified": ["post-release-validation"],
      "verified->closed": ["followups-linked"]
    },
    "responsibleAgent": {
      "triage": "product-owner",
      "planned": "program-manager",
      "in-progress": "implementation-engineer",
      "in-review": "qa-test-engineer",
      "ready-to-release": "devops-engineer",
      "released": "sre-engineer",
      "verified": "quality-director"
    },
    "timeouts": {
      "triage": "1d",
      "planned": "2d",
      "in-review": "2d",
      "blocked": "8h-P0P1|2d-P2P3"
    },
    "escalation": {
      "onTimeout": "00-chief-of-staff",
      "onPolicyConflict": "quality-director"
    }
  },
  "specialized": {
    "incident-outage": {
      "states": ["detected", "triage-sev", "mitigated", "stabilized", "resolved", "postmortem", "closed"],
      "allowedTransitions": {
        "detected": ["triage-sev"],
        "triage-sev": ["mitigated"],
        "mitigated": ["stabilized", "resolved"],
        "stabilized": ["resolved", "mitigated"],
        "resolved": ["postmortem"],
        "postmortem": ["closed"],
        "closed": []
      },
      "preconditions": {
        "triage-sev": ["sev-assigned", "incident-commander-assigned"],
        "mitigated": ["mitigation-applied", "stakeholder-update"],
        "postmortem": ["rca-documented"]
      },
      "timeouts": {
        "updates": "SEV0:15m|SEV1:30m|SEV2:60m|SEV3-4:4h"
      },
      "escalation": {
        "rollbackTrigger": "failed-mitigation-twice|blast-radius-expands"
      }
    },
    "security-vulnerability": {
      "states": ["reported", "validated", "severity-assessed", "containment", "patching", "verification", "disclosure", "closed"],
      "allowedTransitions": {
        "reported": ["validated"],
        "validated": ["severity-assessed"],
        "severity-assessed": ["containment"],
        "containment": ["patching"],
        "patching": ["verification"],
        "verification": ["disclosure", "patching"],
        "disclosure": ["closed"],
        "closed": []
      },
      "preconditions": {
        "severity-assessed": ["cvss-recorded", "affected-versions-recorded"],
        "disclosure": ["legal-review-approved", "security-signoff"]
      },
      "timeouts": {
        "criticalContainment": "4h"
      },
      "responsibleAgent": {
        "reported": "security-engineer",
        "disclosure": "legal-counsel"
      }
    },
    "data-migration": {
      "states": ["design", "compatibility-check", "dry-run", "staged-rollout", "production-run", "validation", "decommission-legacy", "closed"],
      "allowedTransitions": {
        "design": ["compatibility-check"],
        "compatibility-check": ["dry-run"],
        "dry-run": ["staged-rollout"],
        "staged-rollout": ["production-run", "dry-run"],
        "production-run": ["validation"],
        "validation": ["decommission-legacy", "production-run"],
        "decommission-legacy": ["closed"],
        "closed": []
      },
      "preconditions": {
        "dry-run": ["representative-dataset", "rollback-script-tested"],
        "production-run": ["sre-approval", "monitoring-ready"],
        "decommission-legacy": ["retention-policy-verified"]
      },
      "responsibleAgent": {
        "design": "data-engineer",
        "validation": "qa-test-engineer"
      }
    },
    "breaking-api-change": {
      "states": ["proposal", "consumer-impact-analysis", "version-plan", "dual-run", "deprecation-announced", "cutover", "old-version-sunset", "closed"],
      "allowedTransitions": {
        "proposal": ["consumer-impact-analysis"],
        "consumer-impact-analysis": ["version-plan"],
        "version-plan": ["dual-run"],
        "dual-run": ["deprecation-announced", "version-plan"],
        "deprecation-announced": ["cutover"],
        "cutover": ["old-version-sunset"],
        "old-version-sunset": ["closed"],
        "closed": []
      },
      "preconditions": {
        "consumer-impact-analysis": ["consumer-inventory", "migration-owner-assigned"],
        "deprecation-announced": ["notice-published", "support-window-declared"]
      },
      "responsibleAgent": {
        "proposal": "solution-architect",
        "deprecation-announced": "product-owner"
      }
    },
    "hotfix-fast-path": {
      "states": ["triggered", "scoped", "fix-implemented", "expedited-review", "released", "post-release-audit", "closed"],
      "allowedTransitions": {
        "triggered": ["scoped"],
        "scoped": ["fix-implemented"],
        "fix-implemented": ["expedited-review"],
        "expedited-review": ["released", "fix-implemented"],
        "released": ["post-release-audit"],
        "post-release-audit": ["closed"],
        "closed": []
      },
      "preconditions": {
        "triggered": ["priority-is-P0-or-P1", "prod-impact-confirmed"],
        "expedited-review": ["qa-approval", "eng-lead-approval", "sre-approval"],
        "post-release-audit": ["followup-issue-linked"]
      },
      "timeouts": {
        "post-release-audit": "24h"
      },
      "responsibleAgent": {
        "triggered": "incident-commander",
        "released": "sre-engineer"
      }
    }
  }
}
