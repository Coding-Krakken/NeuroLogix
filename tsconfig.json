{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@neurologix/core": ["./packages/core/src"],
      "@neurologix/core/*": ["./packages/core/src/*"],
      "@neurologix/schemas": ["./packages/schemas/src"],
      "@neurologix/schemas/*": ["./packages/schemas/src/*"],
      "@neurologix/security": ["./packages/security/src"],
      "@neurologix/security/*": ["./packages/security/src/*"],
      "@neurologix/observability": ["./packages/observability/src"],
      "@neurologix/observability/*": ["./packages/observability/src/*"],
      "@neurologix/adapters": ["./packages/adapters/src"],
      "@neurologix/adapters/*": ["./packages/adapters/src/*"],
      "@neurologix/ai": ["./packages/ai/src"],
      "@neurologix/ai/*": ["./packages/ai/src/*"],
      "@neurologix/ui": ["./packages/ui/src"],
      "@neurologix/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx"],
  "exclude": [
    "node_modules",
    "build",
    "dist",
    ".next",
    "coverage",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    { "path": "./packages/core" },
    { "path": "./packages/schemas" },
    { "path": "./packages/security" },
    { "path": "./packages/observability" },
    { "path": "./packages/adapters" },
    { "path": "./packages/ai" },
    { "path": "./packages/ui" },
    { "path": "./apps/mission-control" },
    { "path": "./apps/edge-gateway" },
    { "path": "./services/capability-registry" },
    { "path": "./services/policy-engine" },
    { "path": "./services/recipe-executor" },
    { "path": "./services/digital-twin" }
  ]
}