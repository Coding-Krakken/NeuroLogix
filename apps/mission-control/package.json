{
  "name": "@neurologix/mission-control",
  "version": "0.1.0",
  "private": true,
  "description": "Mission Control application foundation with deterministic command-center and line-view APIs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "build:watch": "tsc --build --watch",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "vitest run --coverage",
    "test:contracts": "vitest run --reporter=verbose src/server.contract.test.ts",
    "test:contracts:consumer": "vitest run --reporter=verbose src/consumer.contract.test.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@neurologix/adapters": "*",
    "@neurologix/site-registry": "*",
    "@neurologix/ui": "*",
    "@neurologix/schemas": "*",
    "fastify": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
