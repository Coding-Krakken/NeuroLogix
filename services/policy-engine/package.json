{
  "name": "@neurologix/policy-engine",
  "version": "0.1.0",
  "description": "Policy Engine service with OPA/Rego integration for safety guardrails and approval workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:contracts": "vitest run src/contracts/policy-engine.contract.test.ts",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@neurologix/core": "*",
    "@neurologix/security-core": "*",
    "@neurologix/schemas": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "policy-engine",
    "opa",
    "rego",
    "industrial-automation",
    "safety",
    "compliance",
    "neurologix"
  ],
  "author": "NeuroLogix Team",
  "license": "MIT"
}
