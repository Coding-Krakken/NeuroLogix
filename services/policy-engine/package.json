{
  "name": "@neurologix/policy-engine",
  "version": "0.1.0",
  "description": "Policy Engine service with OPA/Rego integration for safety guardrails and approval workflows",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@neurologix/core": "*",
    "@neurologix/schemas": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "policy-engine",
    "opa",
    "rego",
    "industrial-automation",
    "safety",
    "compliance",
    "neurologix"
  ],
  "author": "NeuroLogix Team",
  "license": "MIT"
}