{
  "name": "@neurologix/recipe-executor",
  "version": "0.1.0",
  "description": "Recipe Executor service for enterprise-grade automation sequencing with safety controls",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "test": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:contracts": "npm run build --workspace @neurologix/core && npm run build --workspace @neurologix/schemas && vitest run src/contracts/recipe-executor.contract.test.ts",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@neurologix/core": "*",
    "@neurologix/schemas": "*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "keywords": [
    "recipe-executor",
    "automation-sequencing",
    "safety-controls",
    "industrial-automation",
    "neurologix"
  ],
  "author": "NeuroLogix Team",
  "license": "MIT"
}
